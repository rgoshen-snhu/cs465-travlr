<div id="contents">
	<div class="box">
		<div>
			<div class="body">
				<h1>Travel</h1>
				<ul id="sites">
					{{#each trips}}
					<li>
						<a href="/api/trips/{{this.code}}"><img src="images/{{this.image}}" alt="Img"></a>
						<h2><a href="/travel">{{this.name}}</a></h2>
						<p>
							{{{this.description}}}
						</p>
						{{#if @root.isLoggedIn}}
						<a href="/book/{{this.code}}" class="btn-book">Book Trip</a>
						{{/if}}
					</li>
					{{/each}}
				</ul>
			</div>
		</div>
	</div>
</div>
