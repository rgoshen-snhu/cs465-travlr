# Travlr Getaways — environment configuration
# Copy this file to `.env` and replace the placeholder values below.

# Port for the Express server (public site + /api). Defaults to 3000 if unset.
PORT=3000

# MongoDB host:port. The database name is always `travlr`.
DB_HOST=127.0.0.1:27017

# Signing key for JWT access tokens. Replace with a long, random string.
# Example generator: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=replace-with-a-long-random-string
